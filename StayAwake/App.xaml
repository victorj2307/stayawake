<Application x:Class="StayAwake.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StayAwake">
    <Application.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="WindowBgBase" Color="#07070F"/>
        <SolidColorBrush x:Key="CardBg" Color="#1A1A2C"/>
        <SolidColorBrush x:Key="InputBg" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="InputBgDisabled" Color="#161622"/>
        <SolidColorBrush x:Key="InputHoverBg" Color="#2A2A40"/>
        <SolidColorBrush x:Key="InputInsetOuter" Color="#06060C"/>
        <SolidColorBrush x:Key="InputInsetFrame" Color="#101018"/>
        <SolidColorBrush x:Key="InputBorderInset" Color="#252538"/>
        <SolidColorBrush x:Key="BorderSubtle" Color="#32324A"/>
        <SolidColorBrush x:Key="BorderDisabled" Color="#282838"/>
        <SolidColorBrush x:Key="CardBorderLight" Color="#30FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A0A0A0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#666666"/>
        <SolidColorBrush x:Key="AccentPrimary" Color="#A855F7"/>
        <SolidColorBrush x:Key="AccentPrimaryDim" Color="#2D1F4A"/>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#A855F7" Offset="0"/>
            <GradientStop Color="#3B82F6" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="IconAccent" Color="#A855F7"/>
        <SolidColorBrush x:Key="PresetBorderActive" Color="#A855F7"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#3DD68C"/>
        <LinearGradientBrush x:Key="EnabledActiveGradient" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#353DD68C" Offset="0"/>
            <GradientStop Color="#203DD68C" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="EnabledActiveBorder" Color="#503DD68C"/>
        <SolidColorBrush x:Key="StatusDisabled" Color="#8A8A8A"/>
        <SolidColorBrush x:Key="StatusCompleted" Color="#7EB8DA"/>
        <SolidColorBrush x:Key="ToggleTrackOff" Color="#2E2E3A"/>
        <SolidColorBrush x:Key="ToggleTrackBorder" Color="#4A4A60"/>
        <SolidColorBrush x:Key="ToggleThumb" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="PresetBorderPreferred" Color="#4A4A60"/>
        <SolidColorBrush x:Key="PresetBgPreferred" Color="#2A2A3A"/>

        <DropShadowEffect x:Key="CardElevation"
                          BlurRadius="22"
                          ShadowDepth="3"
                          Direction="270"
                          Opacity="0.42"
                          Color="#000000"/>

        <!-- Override system highlight colors for ComboBox dropdown -->
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2D1F4A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1A1A28"/>

        <!-- Card -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Effect" Value="{StaticResource CardElevation}"/>
        </Style>

        <Style x:Key="EnabledCardBorder" TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:AppStatus.Active}">
                    <Setter Property="Background" Value="{StaticResource EnabledActiveGradient}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource EnabledActiveBorder}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Setting rows: margin between rows; controls top-aligned (see SettingRowIcon) -->
        <Style x:Key="SettingRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SettingRowLast" TargetType="Grid" BasedOn="{StaticResource SettingRow}">
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="12,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="SettingHint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin" Value="12,2,12,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="StatusRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="MinHeight" Value="22"/>
        </Style>

        <Style x:Key="StatusRowLast" TargetType="Grid" BasedOn="{StaticResource StatusRow}">
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="StatusLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="StatusValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>

        <!-- Segoe MDL2 icon -->
        <Style x:Key="IconGlyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource IconAccent}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SettingRowIcon" TargetType="TextBlock" BasedOn="{StaticResource IconGlyph}">
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <!-- Status dot -->
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Fill" Value="{StaticResource StatusDisabled}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:AppStatus.Active}">
                    <Setter Property="Fill" Value="{StaticResource AccentGreen}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static local:AppStatus.SessionCompleted}">
                    <Setter Property="Fill" Value="{StaticResource StatusCompleted}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle switch (small, ~22px) -->
        <Style x:Key="UtilityToggle" TargetType="ToggleButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track"
                                Width="44" Height="22"
                                CornerRadius="11"
                                Background="{StaticResource ToggleTrackOff}"
                                BorderBrush="{StaticResource ToggleTrackBorder}"
                                BorderThickness="1">
                            <Ellipse x:Name="Thumb"
                                     Width="18" Height="18"
                                     Fill="{StaticResource ToggleThumb}"
                                     HorizontalAlignment="Left"
                                     Margin="2,0,0,0"
                                     VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentGradient}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle switch (enable row) -->
        <Style x:Key="UtilityToggleLarge" TargetType="ToggleButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track"
                                Width="52" Height="28"
                                CornerRadius="14"
                                Background="{StaticResource ToggleTrackOff}"
                                BorderBrush="{StaticResource ToggleTrackBorder}"
                                BorderThickness="1">
                            <Ellipse x:Name="Thumb"
                                     Width="22" Height="22"
                                     Fill="{StaticResource ToggleThumb}"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0"
                                     VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentGradient}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox -->
        <Style x:Key="UtilityTextBox" TargetType="TextBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InsetFrame"
                                CornerRadius="7"
                                BorderBrush="{StaticResource InputInsetOuter}"
                                BorderThickness="1"
                                Background="{StaticResource InputInsetFrame}">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource InputBorderInset}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource InputBgDisabled}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderDisabled}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="CaretBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Numeric stepper inner text (borderless inside composite control) -->
        <Style x:Key="UtilityNumericStepperTextBox" TargetType="TextBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Numeric stepper up/down buttons -->
        <Style x:Key="UtilityStepperButton" TargetType="RepeatButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource InputHoverBg}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource InputBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Session duration preset chips (preference hint only, not active-state) -->
        <Style x:Key="UtilityPresetChip" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PresetBorderPreferred}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource InputBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="UtilityComboBox" TargetType="ComboBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="InsetFrame"
                                CornerRadius="7"
                                BorderBrush="{StaticResource InputInsetOuter}"
                                BorderThickness="1"
                                Background="{StaticResource InputInsetFrame}">
                            <Grid SnapsToDevicePixels="True">
                                <Border x:Name="Border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{StaticResource InputBorderInset}"
                                        BorderThickness="1"
                                        CornerRadius="6"/>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="10,0,28,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <TextBlock x:Name="Chevron"
                                       Text="&#xE70D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       IsHitTestVisible="False"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{StaticResource CardBg}"
                                        BorderBrush="{StaticResource BorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,2,0,0">
                                    <ScrollViewer MaxHeight="120" SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource InputBgDisabled}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource BorderDisabled}"/>
                                <Setter TargetName="Chevron" Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UtilityComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentPrimaryDim}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource InputBg}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Footer: subtle secondary action -->
        <Style x:Key="FooterResetButton" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource InputBg}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
