<Window x:Class="StayAwake.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StayAwake"
        Width="680"
        SizeToContent="Height"
        MinHeight="400"
        MaxHeight="572"
        MinWidth="600"
        ResizeMode="CanMinimize"
        Background="{StaticResource WindowBg}"
        Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Width="36" Height="36"
                   Margin="0,0,12,0"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Source>
                    <BitmapImage UriSource="pack://application:,,,/Assets/app-header.png"/>
                </Image.Source>
            </Image>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="StayAwake"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="Keep Windows awake when you need it"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="228"/>
            </Grid.ColumnDefinitions>

            <!-- Main settings -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,10" Padding="12,8">
                    <Grid Height="36">
                        <TextBlock Text="Enabled"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <ToggleButton Style="{StaticResource UtilityToggleLarge}"
                                      IsChecked="{Binding Enabled}"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" IsEnabled="{Binding CanEditSettings}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE121;" Style="{StaticResource IconGlyph}"/>
                        <TextBlock Grid.Column="1" Text="Idle time (seconds)" Style="{StaticResource SettingLabel}"/>
                        <TextBox Grid.Column="2"
                                 Style="{StaticResource UtilityTextBox}"
                                 Text="{Binding IdleSecondsText, UpdateSourceTrigger=LostFocus}"
                                 LostFocus="NumericField_LostFocus"/>
                    </Grid>

                    <Grid Grid.Row="1" Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE962;" Style="{StaticResource IconGlyph}"/>
                        <TextBlock Grid.Column="1" Text="Movement (pixels)" Style="{StaticResource SettingLabel}"/>
                        <TextBox Grid.Column="2"
                                 Style="{StaticResource UtilityTextBox}"
                                 Text="{Binding MovementPixelsText, UpdateSourceTrigger=LostFocus}"
                                 LostFocus="NumericField_LostFocus"/>
                    </Grid>

                    <Grid Grid.Row="2" Style="{StaticResource SettingRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE8B8;" Style="{StaticResource IconGlyph}"/>
                        <TextBlock Grid.Column="1" Text="Movement direction" Style="{StaticResource SettingLabel}"/>
                        <ComboBox Grid.Column="2"
                                  Style="{StaticResource UtilityComboBox}"
                                  ItemContainerStyle="{StaticResource UtilityComboBoxItem}"
                                  ItemsSource="{Binding MovementModes}"
                                  SelectedItem="{Binding MovementMode}"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="&#xE823;" Style="{StaticResource IconGlyph}"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Run duration (hours)" Style="{StaticResource SettingLabel}" Margin="12,0,12,0"/>
                            <TextBlock Text="Presets start immediately. Hours apply when using Enabled."
                                       FontSize="10"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="12,2,12,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBox Grid.Row="0" Grid.Column="2"
                                 Style="{StaticResource UtilityTextBox}"
                                 HorizontalAlignment="Left"
                                 Text="{Binding SessionDurationHoursText, UpdateSourceTrigger=LostFocus}"
                                 LostFocus="NumericField_LostFocus"/>
                        <Grid Grid.Row="1"
                              Grid.Column="2"
                              Width="140"
                              Margin="0,6,0,0"
                              HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="30m"
                                    Command="{Binding StartPreset30mCommand}"
                                    HorizontalAlignment="Stretch">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource UtilityPresetChip}">
                                        <Setter Property="MinWidth" Value="0"/>
                                        <Setter Property="Padding" Value="0,2"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPreset30mPreferred}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                <Setter Property="Background" Value="{StaticResource PresetBgPreferred}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource PresetBorderPreferred}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Grid.Column="2"
                                    Content="1h"
                                    Command="{Binding StartPreset1hCommand}"
                                    HorizontalAlignment="Stretch">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource UtilityPresetChip}">
                                        <Setter Property="MinWidth" Value="0"/>
                                        <Setter Property="Padding" Value="0,2"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPreset1hPreferred}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                <Setter Property="Background" Value="{StaticResource PresetBgPreferred}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource PresetBorderPreferred}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Grid.Column="4"
                                    Content="3h"
                                    Command="{Binding StartPreset3hCommand}"
                                    HorizontalAlignment="Stretch">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource UtilityPresetChip}">
                                        <Setter Property="MinWidth" Value="0"/>
                                        <Setter Property="Padding" Value="0,2"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPreset3hPreferred}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                <Setter Property="Background" Value="{StaticResource PresetBgPreferred}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource PresetBorderPreferred}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Grid.Column="6"
                                    Content="&#x221E;"
                                    Command="{Binding StartPresetIndefiniteCommand}"
                                    ToolTip="Indefinite"
                                    HorizontalAlignment="Stretch">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource UtilityPresetChip}">
                                        <Setter Property="MinWidth" Value="0"/>
                                        <Setter Property="Padding" Value="0,2"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPresetIndefinitePreferred}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                <Setter Property="Background" Value="{StaticResource PresetBgPreferred}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource PresetBorderPreferred}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="4" Style="{StaticResource SettingRowLast}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE74A;" Style="{StaticResource IconGlyph}"/>
                        <TextBlock Grid.Column="1" Text="Minimize to tray" Style="{StaticResource SettingLabel}"/>
                        <Grid Grid.Column="2" Width="140" HorizontalAlignment="Left">
                            <ToggleButton Style="{StaticResource UtilityToggle}"
                                          IsChecked="{Binding MinimizeToTray}"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Status -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="10,10" VerticalAlignment="Top">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="3"
                               Text="Status"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentGreen}"
                               Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="State"
                               Style="{StaticResource StatusLabel}"
                               Margin="0,0,0,6"/>
                    <StackPanel Grid.Row="1"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                Margin="0,0,0,6">
                        <Ellipse Style="{StaticResource StatusDot}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusPillText}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="{Binding RemainingLabelText}"
                               Style="{StaticResource StatusLabel}"
                               Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               Text="{Binding RemainingDisplayText}"
                               Style="{StaticResource StatusValue}"
                               Foreground="{StaticResource AccentGreen}"
                               Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Text="Last movement"
                               Style="{StaticResource StatusLabel}"/>
                    <TextBlock Grid.Row="3"
                               Grid.Column="2"
                               Text="{Binding LastMovementValue}"
                               Style="{StaticResource StatusValue}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding FooterVersionText}"
                       FontSize="11"
                       Foreground="{StaticResource TextMuted}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="Reset settings"
                    Style="{StaticResource FooterResetButton}"
                    Command="{Binding ResetSettingsCommand}"/>
        </Grid>
    </Grid>
</Window>
